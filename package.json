{
  "name": "saldofacil-react",
  "private": true,
  "version": "1.0.0",
  "description": "SaldoFacil - controle financeiro pessoal",
  "author": "Autossuficiencia",
  "type": "module",
  "main": "desktop/windows/main.cjs",
  "scripts": {
    "assets:icons": "node generate-icons.mjs",
    "assets:store": "node scripts/generate-store-assets.mjs",
    "prebuild": "npm run assets:icons",
    "dev": "vite",
    "build": "vite build",
    "build:web": "vite build",
    "predesktop:dir": "npm run assets:icons",
    "predesktop:appx": "npm run assets:icons",
    "predesktop:setup": "npm run assets:icons",
    "desktop:dev": "cross-env VITE_DEV_SERVER_URL=http://localhost:5173 concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron desktop/windows/main.cjs\"",
    "desktop:dir": "npm run build:web && electron-builder --config electron-builder.cjs --win dir",
    "desktop:setup": "npm run build:web && electron-builder --config electron-builder.cjs --win nsis",
    "desktop:appx": "npm run build:web && electron-builder --config electron-builder.cjs --win appx",
    "desktop:appx:store": "powershell -ExecutionPolicy Bypass -File ./scripts/build-store-appx.ps1",
    "lint": "eslint .",
    "preview": "vite preview",
    "deps:check": "npx npm-check-updates",
    "deps:update": "npx npm-check-updates -u ; npm install"
  },
  "dependencies": {
    "exceljs": "^4.4.0",
    "firebase": "^12.15.0",
    "groq-sdk": "^1.2.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "react-swipeable": "^7.0.2",
    "recharts": "^3.8.1"
  },
  "overrides": {
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "icojs": "^1.0.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.35.1",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0",
    "wait-on": "^9.0.10",
    "workbox-window": "^7.4.1"
  }
}
